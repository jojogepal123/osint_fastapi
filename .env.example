TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash

SERP_API_KEY=your_serpapi_key
SERP_API_URL=https://serpapi.com/search

# GHunt credentials (avoids interactive `ghunt login` inside the container)
# How to get this value:
#   1. Start the container and run: docker compose exec python ghunt login
#   2. After login, run: docker compose exec python cat /ghunt-creds/ghunt_keys.json
#   3. Paste the output here as a single line
GHUNT_KEYS_JSON=
